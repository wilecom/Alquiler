# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# N8N (server-only — used by notify() helper)
N8N_BASE_URL=https://primary-production-7a21b.up.railway.app
N8N_API_KEY=
N8N_WEBHOOK_COMPROBANTE=https://primary-production-7a21b.up.railway.app/webhook/comprobante-pago
N8N_WEBHOOK_APLAZATORIA=https://primary-production-7a21b.up.railway.app/webhook/aplazatoria-resuelta

# Meta WhatsApp Cloud API (server-only — never NEXT_PUBLIC)
META_APP_ID=
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_VERSION=v25.0
META_ACCESS_TOKEN=

# Equipo (alertas internas: mora, comparendos, aplazatorias pendientes)
# Formato: indicativo + número, sin '+', sin espacios. Ej: 573001234567
EQUIPO_WHATSAPP=
