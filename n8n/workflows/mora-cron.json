{
  "name": "Leasing - Mora Diaria (cron)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 14 * * *"
            }
          ]
        }
      },
      "id": "sched-mora",
      "name": "Diario 9am Bogotá",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://nyqzwlawchvvqnwwopxc.supabase.co/rest/v1/pagos?select=id,contrato_id,monto,fecha_vencimiento,contratos(conductor_id,vehiculos(placa),conductores(nombre_completo,telefono))&estado=eq.pendiente&fecha_vencimiento=lt.{{ $now.format('yyyy-MM-dd') }}&order=fecha_vencimiento.asc",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55cXp3bGF3Y2h2dnFud3dvcHhjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzQyNzM2MSwiZXhwIjoyMDkzMDAzMzYxfQ.497m4yMeegxFzqnsedfsDTx_vilVjkxUtZCX-z0iBZY"
            }
          ]
        },
        "options": {}
      },
      "id": "http-supabase",
      "name": "Supabase - Pagos en mora",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "1Lhy6PNC90ObruJX",
          "name": "Supabase Leasing (service_role)"
        }
      }
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "id": "split-001",
      "name": "Por cada pago",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "m1",
              "name": "telefono",
              "value": "={{ $json.contratos.conductores.telefono }}",
              "type": "string"
            },
            {
              "id": "m2",
              "name": "nombre",
              "value": "={{ $json.contratos.conductores.nombre_completo }}",
              "type": "string"
            },
            {
              "id": "m3",
              "name": "dias_mora",
              "value": "={{ Math.ceil((new Date() - new Date($json.fecha_vencimiento)) / 86400000) }}",
              "type": "number"
            },
            {
              "id": "m4",
              "name": "multa",
              "value": "={{ Math.ceil((new Date() - new Date($json.fecha_vencimiento)) / 86400000) * 5000 }}",
              "type": "number"
            },
            {
              "id": "m5",
              "name": "placa",
              "value": "={{ $json.contratos.vehiculos.placa }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "calc-mora",
      "name": "Calcular días/multa",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.dias_mora }}",
              "rightValue": 5,
              "operator": {
                "type": "number",
                "operation": "lte"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-day-leq5",
      "name": "Mora <= 5 días",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v25.0/1055022657703124/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ messaging_product: 'whatsapp', to: $json.telefono, type: 'template', template: { name: $json.dias_mora === 3 ? 'mora_dia_3_critico' : $json.dias_mora === 5 ? 'mora_dia_5_ultimo' : 'recordatorio_mora', language: { code: 'es' }, components: [{ type: 'body', parameters: ($json.dias_mora === 3 || $json.dias_mora === 5) ? [{ type: 'text', text: String($json.nombre) }, { type: 'text', text: String($json.multa) }] : [{ type: 'text', text: String($json.nombre) }, { type: 'text', text: String($json.dias_mora) }, { type: 'text', text: String($json.multa) }] }] } }) }}",
        "options": {}
      },
