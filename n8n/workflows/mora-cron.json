        "jsonBody": "={{ JSON.stringify({ messaging_product: 'whatsapp', to: '573044903559', type: 'template', template: { name: 'equipo_alerta_mora', language: { code: 'es' }, components: [{ type: 'body', parameters: [{ type: 'text', text: String($json.nombre) }, { type: 'text', text: String($json.placa) }, { type: 'text', text: String($json.multa) }] }] } }) }}",
        "options": {}
